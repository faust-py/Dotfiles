#!/usr/bin/env bash

# Paths
awesome_file=~/.config/awesome/themes/init.lua
rofi_file=~/.config/rofi/config.rasi
rofi_menu_file=~/.config/awesome/libs/misc/rofi/config.rasi
nvim_file=~/.config/nvim/lua/colorschames/misery.lua
kitty_file=~/.config/kitty/kitty.conf
gtk3_file=~/.config/gtk-3.0/settings.ini
gtk4_file=~/.config/gtk-4.0/settings.ini

# Theme options
declare -A themes
themes["Otis Forest"]="Otis-forest|otis_forest|otis-forest|themes/otis-forest.conf"
themes["Doom"]="Matcha-dark-azul|doom|doom|themes/doom.conf"
themes["Kripton"]="Kripton-v40|kripton|kripton|themes/kripton.conf"
themes["Gruvbox"]="Gruvbox|gruvbox|gruvbox-dark|themes/gruvbox.conf"
themes["Berry"]="Otis|berry|berry|themes/berry.conf"
themes["Matcha Sea"]="Matcha-dark-sea|matcha_sea|matcha-sea|themes/matcha-sea.conf"
themes["Matcha Azul"]="Matcha-dark-azul|matcha_azul|matcha-azul|themes/matcha-azul.conf"
themes["Matcha Aliz"]="Matcha-dark-aliz|matcha_aliz|matcha-aliz|themes/matcha-aliz.conf"

# List options in Rofi
options=$(printf "%s\n" "${!themes[@]}")
chosen=$(echo -e "$options" | rofi -show -dmenu -selected-row 0)

# Exit if nothing selected
[[ -z $chosen ]] && exit

# Parse selected theme
IFS='|' read -r gtk_theme wm_theme rofi_theme kitty_theme <<< "${themes[$chosen]}"

# Notify
notify-send "Changing Theme to $chosen" -t 1500

# GTK Theme
gsettings set org.gnome.desktop.interface gtk-theme "$gtk_theme"
for gtk_file in "$gtk3_file" "$gtk4_file"; do
    sed -i 's/^gtk-theme-name=.*/gtk-theme-name='"$gtk_theme"'/' "$gtk_file"
done

# Kitty
sed -i 's|^include .*|include '"$kitty_theme"'|' "$kitty_file"

# Neovim
sed -i 's|^\s*style\s*=.*|    style = "'"$wm_theme"'"|' "$nvim_file"

# Rofi
sed -i "s|@import.*|@import \"$rofi_theme\"|" "$rofi_file"


# AwesomeWM
# Get current theme name from init.lua
awesome_theme="$(grep 'colors =' "$awesome_file" | cut -d'"' -f2)"
sed -i "s/^colors = .*/colors = $wm_theme/" "$awesome_file"
# Reload AwesomeWM
echo 'awesome.restart()' | awesome-client

